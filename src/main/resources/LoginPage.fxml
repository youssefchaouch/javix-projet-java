<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controllers.LoginController"
            style="-fx-background-color: #f7f9fc;">

    <!-- Header -->
    <top>
        <VBox style="-fx-background-color: #74b9ff;">
            <padding>
                <Insets top="30" bottom="30" left="30" right="30"/>
            </padding>

            <Label text="HR Management System"
                   style="-fx-text-fill: white;
                          -fx-font-size: 28px;
                          -fx-font-weight: bold;
                          -fx-font-family: 'Segoe UI';"/>

            <Label text="Login or Continue"
                   style="-fx-text-fill: #ecf0f1;
                          -fx-font-size: 15px;
                          -fx-font-family: 'Segoe UI';"/>
        </VBox>
    </top>

    <!-- Center Content -->
    <center>
        <VBox alignment="CENTER" spacing="25">
            <padding>
                <Insets top="60" bottom="60" left="60" right="60"/>
            </padding>

            <!-- Login Card -->
            <VBox spacing="20"
                  alignment="CENTER"
                  maxWidth="400"
                  style="-fx-background-color: #ffffff;
                         -fx-background-radius: 15;
                         -fx-padding: 40;
                         -fx-border-color: #dfe6e9;
                         -fx-border-radius: 15;">

                <Label text="HR Login"
                       style="-fx-font-size: 22px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #2d3436;"/>

                <TextField fx:id="usernameField"
                           promptText="Username"
                           prefWidth="260"/>

                <PasswordField fx:id="passwordField"
                               promptText="Password"
                               prefWidth="260"/>

                <Button text="Login"
                        fx:id="loginButton"
                        prefWidth="260"
                        prefHeight="45"
                        onAction="#handleLogin"
                        style="-fx-background-color: #6c5ce7;
                               -fx-text-fill: white;
                               -fx-font-size: 15px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-cursor: hand;"/>

                <Label fx:id="errorLabel"
                       textFill="red"
                       style="-fx-font-size: 13px;"/>
            </VBox>

            <!-- Candidate Button -->
            <Button text="🧑‍💼 Candidate Portal"
                    fx:id="candidateButton"
                    prefWidth="260"
                    prefHeight="45"
                    onAction="#candidateButtonClicked"
                    style="-fx-background-color: #00cec9;
                           -fx-text-fill: white;
                           -fx-font-size: 15px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 10;
                           -fx-cursor: hand;"/>
        </VBox>
    </center>

    <!-- Footer -->
    <bottom>
        <HBox alignment="CENTER">
            <padding>
                <Insets bottom="15"/>
            </padding>

            <Label text="© 2026 HR System"
                   style="-fx-text-fill: #636e72;
                          -fx-font-size: 12px;"/>
        </HBox>
    </bottom>

</BorderPane>
