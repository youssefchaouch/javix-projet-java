<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controllers.HRMenuController"
            style="-fx-background-color: #f7f9fc; -fx-font-family: 'Segoe UI';">

    <!-- Top Header -->
    <top>
        <BorderPane style="-fx-background-color: #74b9ff;">
            <padding>
                <Insets top="30" bottom="30" left="40" right="40"/>
            </padding>

            <left>
                <Label text="HR Dashboard"
                       style="-fx-text-fill: white;
                              -fx-font-size: 28px;
                              -fx-font-weight: bold;"/>
            </left>

            <right>
                <Button fx:id="logoutButton"
                        text="⎋ Logout"
                        onAction="#handleLogout"
                        style="-fx-background-color: #d63031;
                               -fx-text-fill: white;
                               -fx-font-size: 16px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-padding: 12 20;
                               -fx-cursor: hand;"/>
            </right>
        </BorderPane>
    </top>

    <!-- Main Content -->
    <center>
        <VBox alignment="CENTER" spacing="40">
            <padding>
                <Insets top="60" bottom="60" left="60" right="60"/>
            </padding>

            <!-- Welcome Card -->
            <VBox alignment="CENTER" spacing="15"
                  style="-fx-background-color: #ffffff;
                         -fx-background-radius: 18;
                         -fx-padding: 35;
                         -fx-border-color: #dfe6e9;
                         -fx-border-radius: 18;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10,0,0,4);">

                <Label text="Welcome 👋"
                       style="-fx-font-size: 22px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #2d3436;"/>

                <Label text="Manage job offers and candidates easily"
                       style="-fx-text-fill: #636e72;
                              -fx-font-size: 14px;"/>
            </VBox>

            <!-- Action Buttons Card -->
            <VBox spacing="25" alignment="CENTER"
                  style="-fx-background-color: #ffffff;
                         -fx-background-radius: 18;
                         -fx-padding: 40;
                         -fx-border-color: #dfe6e9;
                         -fx-border-radius: 18;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10,0,0,4);">

                <Label text="Quick Actions"
                       style="-fx-font-size: 20px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #0984e3;"/>

                <Button text="➕ Add Job Offer"
                        fx:id="addJobButton"
                        prefWidth="280"
                        prefHeight="55"
                        onAction="#addJobClicked"
                        style="-fx-background-color: #0984e3;
                               -fx-text-fill: white;
                               -fx-font-size: 16px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 12;
                               -fx-padding: 14 24;
                               -fx-cursor: hand;"/>

                <Button text="📋 Candidates List"
                        fx:id="checkCandidatesButton"
                        prefWidth="280"
                        prefHeight="55"
                        onAction="#checkCandidatesClicked"
                        style="-fx-background-color: #00b894;
                               -fx-text-fill: white;
                               -fx-font-size: 16px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 12;
                               -fx-padding: 14 24;
                               -fx-cursor: hand;"/>
            </VBox>
        </VBox>
    </center>
</BorderPane>
