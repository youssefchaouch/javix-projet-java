<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controllers.HRMenuController"
            style="-fx-background-color: #f7f9fc;">

    <top>
        <BorderPane style="-fx-background-color: #74b9ff;">
            <padding>
                <Insets top="25" bottom="25" left="25" right="25"/>
            </padding>

            <left>
                <Label text="HR Dashboard"
                       style="-fx-text-fill: white;
                          -fx-font-size: 24px;
                          -fx-font-weight: bold;
                          -fx-font-family: 'Segoe UI';"/>
            </left>

            <right>
                <Button fx:id="logoutButton"
                        text="⎋ Logout"
                        onAction="#handleLogout"
                        style="-fx-background-color: #d63031;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-padding: 8 16;
                           -fx-cursor: hand;
                           -fx-font-family: 'Segoe UI';"/>
            </right>
        </BorderPane>
    </top>


    <!-- Main Content -->
    <center>
        <VBox alignment="CENTER" spacing="30">
            <padding>
                <Insets top="40" bottom="40" left="40" right="40"/>
            </padding>

            <!-- Welcome Card -->
            <VBox alignment="CENTER" spacing="10"
                  style="-fx-background-color: #ffffff;
                         -fx-background-radius: 15;
                         -fx-padding: 25;
                         -fx-border-color: #dfe6e9;
                         -fx-border-radius: 15;">

                <Label text="Welcome 👋"
                       style="-fx-font-size: 20px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #2d3436;"/>

                <Label text="Manage job offers and candidates easily"
                       style="-fx-text-fill: #636e72;"/>
            </VBox>

            <!-- Action Buttons Card -->
            <VBox spacing="18" alignment="CENTER"
                  style="-fx-background-color: #ffffff;
                         -fx-background-radius: 15;
                         -fx-padding: 30;
                         -fx-border-color: #dfe6e9;
                         -fx-border-radius: 15;">

                <Label text="Quick Actions"
                       style="-fx-font-size: 18px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #0984e3;"/>

                <Button text="➕ Add Job Offer"
                        fx:id="addJobButton"
                        prefWidth="240"
                        onAction="#addJobClicked"
                        style="-fx-background-color: #0984e3;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-padding: 12 18;
                               -fx-cursor: hand;
                               -fx-font-family: 'Segoe UI';"/>

                <Button text="📋 Candidates List"
                        fx:id="checkCandidatesButton"
                        prefWidth="240"
                        onAction="#checkCandidatesClicked"
                        style="-fx-background-color: #00b894;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-padding: 12 18;
                               -fx-cursor: hand;
                               -fx-font-family: 'Segoe UI';"/>
            </VBox>

        </VBox>
    </center>

</BorderPane>
