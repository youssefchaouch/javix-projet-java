<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controllers.CandidateListController"
            style="-fx-background-color: #f7f9fc; -fx-font-family: 'Segoe UI';">

    <!-- Top Header -->
    <top>
        <VBox style="-fx-background-color: #6c5ce7; -fx-padding: 20;">
            <Label text="Candidates Management"
                   style="-fx-text-fill: white;
                          -fx-font-size: 22px;
                          -fx-font-weight: bold;"/>
        </VBox>
    </top>

    <!-- Main Content -->
    <center>
        <VBox spacing="20">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- Search Bar -->
            <HBox spacing="10" alignment="CENTER_LEFT"
                  style="-fx-background-color: #ffffff;
                         -fx-background-radius: 12;
                         -fx-padding: 12;
                         -fx-border-color: #dfe6e9;
                         -fx-border-radius: 12;">
                <Label text="🔍" style="-fx-font-size: 16px;"/>
                <TextField fx:id="searchField"
                           promptText="Search by name or email..."
                           HBox.hgrow="ALWAYS"
                           style="-fx-background-radius: 8;
                                  -fx-padding: 8;
                                  -fx-border-color: #b2bec3;
                                  -fx-border-radius: 8;"/>
            </HBox>

            <!-- Candidate List Card -->
            <VBox spacing="12" alignment="CENTER" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: #ffffff;
                         -fx-background-radius: 12;
                         -fx-padding: 18;
                         -fx-border-color: #dfe6e9;
                         -fx-border-radius: 12;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8,0,0,2);">
                <Label text="Candidate List"
                       style="-fx-font-size: 18px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #2d3436;
                              -fx-padding: 0 0 10 0;"/>

                <TableView fx:id="candidateTable"
                           VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #ffffff;
                                  -fx-background-radius: 10;
                                  -fx-border-color: #dfe6e9;
                                  -fx-border-radius: 10;
                                  -fx-font-size: 14px;
                                  -fx-selection-bar: #74b9ff;
                                  -fx-selection-bar-non-focused: #dfe6e9;
                                  -fx-padding: 8;"
                           prefHeight="600"
                           prefWidth="1000">

                    <columns>
                        <TableColumn fx:id="idCol" text="ID" prefWidth="70" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="firstNameCol" text="First Name" prefWidth="140" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="lastNameCol" text="Last Name" prefWidth="140" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="emailCol" text="Email" prefWidth="220" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="phoneCol" text="Phone" prefWidth="150" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="statusCol" text="Status" prefWidth="140" style="-fx-alignment: CENTER;"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- Action Buttons -->
            <HBox alignment="CENTER_RIGHT" spacing="12">
                <Button fx:id="saveButton"
                        text="💾 Save Changes"
                        onAction="#handleSave"
                        style="-fx-background-color: #00cec9;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-padding: 10 20;
                               -fx-cursor: hand;"/>
                <Button fx:id="backButton"
                        text="⬅ Back to HR Menu"
                        onAction="#handleBack"
                        style="-fx-background-color: #0984e3;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-padding: 10 20;
                               -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
